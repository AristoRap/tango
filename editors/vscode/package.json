{
  "name": "tango-vscode",
  "displayName": "Tango",
  "description": "Language support for Tango files via tango lsp.",
  "version": "0.0.1",
  "private": true,
  "publisher": "tango-dev",
  "type": "module",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "tango",
        "aliases": [
          "Tango",
          "tango"
        ],
        "extensions": [
          ".tn"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/tango.svg",
          "dark": "./icons/tango.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "tango",
        "scopeName": "source.tango",
        "path": "./syntaxes/tango.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Tango",
      "properties": {
        "tango.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the tango executable. Empty = use <repo>/bin/tango when running from editors/vscode, then fall back to tango on PATH."
        },
        "tango.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication to the Tango output channel."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  }
}
